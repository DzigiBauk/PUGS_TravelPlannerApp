@UserService_HostAddress = http://localhost:5001
@AdminToken = replace-with-admin-jwt
@UserId = 2

POST {{UserService_HostAddress}}/auth/register
Content-Type: application/json

{
  "name": "Test Admin",
  "email": "test-admin@example.com",
  "password": "testing123",
  "role": "Admin"
}

###

GET {{UserService_HostAddress}}/users
Authorization: Bearer {{AdminToken}}
Accept: application/json

###

PATCH {{UserService_HostAddress}}/users/{{UserId}}/role
Authorization: Bearer {{AdminToken}}
Content-Type: application/json

{
  "role": "Admin"
}

###

DELETE {{UserService_HostAddress}}/users/{{UserId}}
Authorization: Bearer {{AdminToken}}

###
